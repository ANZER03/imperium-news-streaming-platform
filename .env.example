# Phase 1 infrastructure foundation
# Copy to .env before running local commands:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Compose project
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=imperium

# -----------------------------------------------------------------------------
# Salted host-port strategy
# Use high prefixed host ports to reduce conflicts with local defaults.
# Check availability on your machine before changing values.
# -----------------------------------------------------------------------------
HOST_PORT_PREFIX=48
KAFKA_EXTERNAL_PORT=49092
KAFKA_BROKER2_EXTERNAL_PORT=49093
SCHEMA_REGISTRY_EXTERNAL_PORT=48081
CONNECT_EXTERNAL_PORT=48083
KAFKA_UI_EXTERNAL_PORT=48089
SPARK_MASTER_EXTERNAL_PORT=47077
SPARK_MASTER_UI_EXTERNAL_PORT=48080
SPARK_WORKER_UI_EXTERNAL_PORT=48091
REDIS_EXTERNAL_PORT=46379
QDRANT_HTTP_EXTERNAL_PORT=46333
QDRANT_GRPC_EXTERNAL_PORT=46334

# -----------------------------------------------------------------------------
# Image families / versions
# Keep aligned with the proven reference projects unless a concrete incompatibility
# requires a change.
# -----------------------------------------------------------------------------
KAFKA_IMAGE=confluentinc/cp-kafka:7.7.7
SCHEMA_REGISTRY_IMAGE=confluentinc/cp-schema-registry:7.7.7
DEBEZIUM_IMAGE=debezium/connect:2.3
SPARK_IMAGE=apache/spark:3.5.3
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.13.4
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest

# -----------------------------------------------------------------------------
# Kafka cluster seed settings
# Generate once if needed with:
# docker run --rm confluentinc/cp-kafka:7.7.7 kafka-storage random-uuid
# -----------------------------------------------------------------------------
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_HEAP_OPTS=-Xmx2g -Xms2g
CONNECT_HEAP_OPTS=-Xmx1g -Xms1g
CONNECT_GROUP_ID=imperium-connect-cluster
CONNECT_CONFIG_STORAGE_TOPIC=imperium.connect.configs
CONNECT_OFFSET_STORAGE_TOPIC=imperium.connect.offsets
CONNECT_STATUS_STORAGE_TOPIC=imperium.connect.statuses
CONNECT_OFFSET_FLUSH_INTERVAL_MS=10000
KAFKA_REPLICATION_FACTOR=2
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_RETENTION_BYTES=5368709120
KAFKA_LOG_SEGMENT_BYTES=536870912
KAFKA_COMPRESSION_TYPE=lz4

# -----------------------------------------------------------------------------
# Schema Registry
# -----------------------------------------------------------------------------
SCHEMA_REGISTRY_COMPATIBILITY=BACKWARD

# -----------------------------------------------------------------------------
# Optional local credentials placeholders
# These are dev-only placeholders and must not be treated as production secrets.
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
QDRANT__SERVICE__API_KEY=

# -----------------------------------------------------------------------------
# Phase 2 CDC rollout
# Keep these aligned with the manual source-readiness runbook and connector assets.
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092,kafka-broker-2:29092

SOURCE_PG_HOST=postgres-source
SOURCE_PG_PORT=5432
SOURCE_PG_DATABASE=imperium-news-source
SOURCE_PG_USER=postgres
SOURCE_PG_PASSWORD=postgres
SOURCE_PG_EXTERNAL_PORT=35432

REFERENCE_CDC_CONNECTOR_NAME=imperium-reference-cdc
REFERENCE_CDC_TOPIC_PREFIX=imperium.reference
REFERENCE_CDC_SCHEMA_HISTORY_TOPIC=imperium.reference.schema-history
REFERENCE_CDC_PUBLICATION_NAME=imperium_reference_publication
REFERENCE_CDC_SLOT_NAME=imperium_reference_slot
REFERENCE_CDC_TABLES=public.table_pays,public.table_langue,public.table_rubrique,public.table_sedition

METADATA_CDC_CONNECTOR_NAME=imperium-metadata-cdc
METADATA_CDC_TOPIC_PREFIX=imperium.metadata
METADATA_CDC_SCHEMA_HISTORY_TOPIC=imperium.metadata.schema-history
METADATA_CDC_SIGNAL_TOPIC=imperium.metadata.signals
METADATA_CDC_PUBLICATION_NAME=imperium_metadata_publication
METADATA_CDC_SLOT_NAME=imperium_metadata_slot
METADATA_CDC_TABLES=public.table_authority,public.table_links
METADATA_CDC_INCREMENTAL_SNAPSHOT_CHUNK_SIZE=8192
METADATA_SINK_AUTHORITY_NAME=imperium-metadata-authority-sink
METADATA_SINK_LINKS_NAME=imperium-metadata-links-sink

TARGET_PG_HOST=
TARGET_PG_PORT=5432
TARGET_PG_DATABASE=
TARGET_PG_USER=
TARGET_PG_PASSWORD=

NEWS_CDC_CONNECTOR_NAME=imperium-news-cdc
NEWS_CDC_TOPIC_PREFIX=imperium.news
NEWS_CDC_SCHEMA_HISTORY_TOPIC=imperium.news.schema-history
NEWS_CDC_SIGNAL_TOPIC=imperium.news.signals
NEWS_CDC_PUBLICATION_NAME=imperium_news_publication
NEWS_CDC_SLOT_NAME=imperium_news_slot
NEWS_CDC_TABLE=public.table_news
NEWS_CDC_BACKFILL_WINDOW_DAYS=5
