# Phase 1 infrastructure foundation
# Copy to .env before running local commands:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Compose project
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=imperium

# -----------------------------------------------------------------------------
# Salted host-port strategy
# Use high prefixed host ports to reduce conflicts with local defaults.
# Check availability on your machine before changing values.
# -----------------------------------------------------------------------------
HOST_PORT_PREFIX=48
KAFKA_EXTERNAL_PORT=49092
KAFKA_BROKER2_EXTERNAL_PORT=49093
SCHEMA_REGISTRY_EXTERNAL_PORT=48081
CONNECT_EXTERNAL_PORT=48083
KAFKA_UI_EXTERNAL_PORT=48089
SPARK_MASTER_EXTERNAL_PORT=47077
SPARK_MASTER_UI_EXTERNAL_PORT=48080
SPARK_WORKER_UI_EXTERNAL_PORT=48091
REDIS_EXTERNAL_PORT=46379
QDRANT_HTTP_EXTERNAL_PORT=46333
QDRANT_GRPC_EXTERNAL_PORT=46334

# -----------------------------------------------------------------------------
# Image families / versions
# Keep aligned with the proven reference projects unless a concrete incompatibility
# requires a change.
# -----------------------------------------------------------------------------
KAFKA_IMAGE=confluentinc/cp-kafka:7.7.7
KARAPACE_IMAGE=ghcr.io/aiven-open/karapace:3.14.0
DEBEZIUM_IMAGE=debezium/connect:2.3
SPARK_IMAGE=apache/spark:3.5.3
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.13.4

# -----------------------------------------------------------------------------
# Kafka cluster seed settings
# Generate once if needed with:
# docker run --rm confluentinc/cp-kafka:7.7.7 kafka-storage random-uuid
# -----------------------------------------------------------------------------
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_HEAP_OPTS=-Xmx2g -Xms2g
CONNECT_HEAP_OPTS=-Xmx1g -Xms1g
CONNECT_GROUP_ID=imperium-connect-cluster
CONNECT_CONFIG_STORAGE_TOPIC=imperium.connect.configs
CONNECT_OFFSET_STORAGE_TOPIC=imperium.connect.offsets
CONNECT_STATUS_STORAGE_TOPIC=imperium.connect.statuses
CONNECT_OFFSET_FLUSH_INTERVAL_MS=10000
KAFKA_REPLICATION_FACTOR=2
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_RETENTION_BYTES=5368709120
KAFKA_LOG_SEGMENT_BYTES=536870912
KAFKA_COMPRESSION_TYPE=lz4

# -----------------------------------------------------------------------------
# Schema Registry
# -----------------------------------------------------------------------------
SCHEMA_REGISTRY_COMPATIBILITY=BACKWARD

# -----------------------------------------------------------------------------
# Optional local credentials placeholders
# These are dev-only placeholders and must not be treated as production secrets.
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
QDRANT__SERVICE__API_KEY=
