    "recommended_confidence_thresholds": {
      "strong_accept": 0.75,
      "weak_accept": 0.5,
      "review_below": 0.5
    },
    "strategy": [
      "Classify first into main_category.",
      "Classify second into sub_category inside the selected main_category.",
      "Extract tags from the allowed tag list.",
      "Allow secondary_categories when the article clearly spans multiple categories.",
      "Use enrichment metadata such as source rubric, URL path, authority, country, language, and edition as confidence signals.",
      "Use rules as confidence boosts, not hard overrides, unless the signal is highly reliable.",
      "Send low-confidence or conflicting classifications to review/retry flow."
    ]
